# ── Gmail OAuth (console.cloud.google.com) ───────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REDIRECT_URI=https://SEU-PROJETO.vercel.app/api/gmail/callback

# Preenchidos automaticamente após clicar em "Conectar Gmail" no painel
GMAIL_ACCESS_TOKEN=
GMAIL_REFRESH_TOKEN=

# ── Codental ──────────────────────────────────────────────────────────────────
CODENTAL_BASE_URL=https://odonto-on-face.codental.com.br
CODENTAL_EMAIL=conta@odonto-on-face.com.br
CODENTAL_PASSWORD=senha_aqui

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# ── Segurança ─────────────────────────────────────────────────────────────────
# Vercel usa CRON_SECRET automaticamente no header Authorization
CRON_SECRET=string_aleatoria_longa_aqui

# API_KEY é usada pelo dashboard para disparar manualmente
API_KEY=outra_string_aleatoria_aqui
