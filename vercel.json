{
  "crons": [
    { "path": "/api/run", "schedule": "0 8 * * *" }
  ],
  "functions": {
    "api/run.js":              { "maxDuration": 300 },
    "api/logs.js":             { "maxDuration": 30  },
    "api/cleanup.js":          { "maxDuration": 120 },
    "api/purge.js":            { "maxDuration": 300 },
    "api/scan-duplicates.js":  { "maxDuration": 300 },
    "api/simulate.js":         { "maxDuration": 300 },
    "api/review.js":           { "maxDuration": 300 },
    "api/sync-patients.js":    { "maxDuration": 120 },
    "api/import-patients.js":  { "maxDuration": 60  },
    "api/debug-search.js":     { "maxDuration": 30  }
  },
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "x-api-key, Content-Type, Authorization" }
      ]
    }
  ]
}